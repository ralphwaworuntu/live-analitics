# ============================================
# SENTINEL — Production Environment Variables
# Biro Operasi Polda NTT
# ============================================
# PENTING: File ini adalah template. 
# Salin ke .env dan isi nilai sebenarnya sebelum deployment.
# JANGAN commit file .env ke Git.
# ============================================

# --- Domain ---
DOMAIN=sentinel.poldantt.polri.go.id

# --- Database (PostGIS) ---
DB_PASSWORD=ganti_dengan_password_kuat_minimal_32_karakter
DATABASE_URL=postgresql+asyncpg://sentinel:${DB_PASSWORD}@db:5432/sentinel_db

# --- Security (JWT) ---
# Generate dengan: openssl rand -hex 32
JWT_SECRET=ganti_dengan_random_hex_32_byte

# --- CORS / Allowed Origins ---
ALLOWED_ORIGINS=https://sentinel.poldantt.polri.go.id

# --- IP Whitelist (kosongkan jika tidak dipakai) ---
# Format: koma separated, contoh: 10.0.0.1,10.0.0.2
IP_WHITELIST=

# --- Ollama AI ---
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3:8b

# --- Google Maps ---
GOOGLE_MAPS_KEY=ganti_dengan_google_maps_api_key
NEXT_PUBLIC_GOOGLE_MAPS_KEY=${GOOGLE_MAPS_KEY}

# --- Object Storage (S3/MinIO) ---
S3_ENDPOINT=
S3_BUCKET=sentinel-uploads
S3_ACCESS_KEY=
S3_SECRET_KEY=

# --- API URL (Internal Docker) ---
API_URL=http://api:8000
NEXT_PUBLIC_API_URL=http://api:8000

# --- Debug Mode (MATIKAN di Production!) ---
DEBUG=false
